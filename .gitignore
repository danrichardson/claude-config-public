# Backups created by install.sh
*.backup.*

# OS junk
.DS_Store
Thumbs.db

# Editor junk
*.swp
*~
.vscode/

# Local-only credentials, if you ever add a secrets file
secrets.md
.env
.env.*

# Per-machine intercom secrets. Everything under secrets/ is ignored
# except the committed template.
secrets/**
!secrets/
!secrets/.env.example

# Rendered MCP config (contains the shared secret) — never committed.
.mcp.json

# Generated by install.sh from CLAUDE.md (single source of truth is CLAUDE.md)
copilot-prompts/claude-global.instructions.md

# Generated by install.sh from plan-mode.md (single source of truth is plan-mode.md)
copilot-prompts/plan-mode.instructions.md

# Generated by install.sh from brainstorm-mode.md (single source of truth is brainstorm-mode.md)
copilot-prompts/brainstorm-mode.instructions.md

# Generated by install.sh from commands/aliases.map — real files, not symlinks
# (one line per alias defined in aliases.map)
commands/tn.md
commands/tl.md
commands/ts.md
commands/ti.md
commands/ta.md
commands/tr.md
commands/tp.md
commands/tb.md
commands/tsh.md
commands/td.md
commands/tc.md
commands/tro.md
commands/tcl.md
commands/tch.md
commands/tdc.md
commands/tam.md

# Rendered Task Scheduler XML (contains username, generated at install time)
windows/*.rendered

# Per-ticket worktrees + preview PID/meta files (created by /ticket-batch, /ticket-chain)
.worktrees/

# Leave-behind review checklists from /ticket-chain Phase 4 (ephemeral, not committed)
CHAIN-REVIEW-*.md

# Scratch plans directory created by /plan-new and similar (ephemeral)
plans/

# VS Code extension build artifacts (extension/ is the travelagent source tree)
extension/node_modules/
extension/dist/
extension/out/
extension/.vscode-test/
# Keep the extension's VS Code debug config (blanket .vscode/ above would exclude it)
!extension/.vscode/

